---
/**
 * ============================================================================
 * GABARIT DE BASE — toutes les pages du site passent par ce fichier.
 * ============================================================================
 * Il fournit :
 *   1. Le <head> SEO complet : titre, description, URL canonique,
 *      Open Graph (partage Facebook/LinkedIn) et Twitter Cards.
 *   2. Les données structurées schema.org (JSON-LD) de type `AutoRepair` :
 *      c'est ce qui permet à Google d'afficher la fiche enrichie (heures,
 *      téléphone, adresse) et aux assistants IA (Claude, ChatGPT, Gemini…)
 *      de citer l'entreprise avec des informations exactes.
 *   3. L'en-tête et le pied de page communs.
 *
 * Usage dans une page :
 *   <Layout title="…" description="…"> contenu </Layout>
 *
 * Les pages n'ont qu'à fournir `title` et `description` — tout le reste est
 * automatique (canonique, OG, JSON-LD).
 * ============================================================================
 */
import '@fontsource-variable/inter';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import { analytics, business, booking, services } from '../data/business';

interface Props {
  /** Titre de la page (balise <title> et réseaux sociaux). */
  title: string;
  /** Description pour les moteurs de recherche (~150 caractères). */
  description: string;
}

const { title, description } = Astro.props;

/** URL canonique absolue de la page courante (basée sur `site` dans astro.config.mjs). */
const canonical = new URL(Astro.url.pathname, Astro.site).href;

/** Image d'aperçu pour les partages sur les réseaux sociaux (1200 × 630). */
const ogImage = new URL('/og-image.png', Astro.site).href;

/**
 * Données structurées schema.org — fiche d'entreprise locale.
 * Type `AutoRepair` (sous-type de LocalBusiness) : reconnu par Google,
 * Bing et les moteurs de réponse IA.
 */
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  '@id': new URL('/', Astro.site).href + '#business',
  name: business.name,
  alternateName: business.shortName,
  url: new URL('/', Astro.site).href,
  telephone: business.phone.e164,
  email: business.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.province,
    postalCode: business.address.postalCode,
    addressCountry: business.address.country,
  },
  openingHours: business.hours.schema,
  areaServed: [...business.areaServed, 'Rive-Sud de Montréal'],
  founder: { '@type': 'Person', name: business.owner },
  brand: business.certifications.map((c) => ({
    '@type': 'Brand',
    name: c.name,
  })),
  knowsLanguage: ['fr-CA'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services automobiles',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.title, description: s.description },
    })),
  },
  // Signale aux moteurs que la prise de rendez-vous en ligne est possible
  // (uniquement quand la réservation Cal.com est activée).
  ...(booking.enabled && {
    potentialAction: {
      '@type': 'ReserveAction',
      target: new URL('/rendez-vous/', Astro.site).href,
      name: 'Prendre rendez-vous en ligne',
    },
  }),
};
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Référencement de base -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph (aperçus Facebook, LinkedIn, Messenger…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={`${business.name} — garage certifié Bumper to Bumper à Varennes`}
    />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Référencement local -->
    <meta name="geo.region" content="CA-QC" />
    <meta name="geo.placename" content={business.address.city} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Couleur de la barre d'adresse sur mobile -->
    <meta name="theme-color" content="#101418" />

    <!-- Données structurées schema.org (fiche entreprise locale) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Balises supplémentaires injectées par certaines pages (ex. FAQ) -->
    <slot name="head" />

    {
      /* Mesure d'audience Plausible (sans témoins — voir
         `analytics` dans src/data/business.ts pour l'activation). */
      analytics.enabled && (
        <script
          defer
          data-domain={analytics.domain}
          src="https://plausible.io/js/script.js"
        />
      )
    }
  </head>
  <body>
    <!-- Lien d'évitement : premier élément focusable au clavier,
         visible uniquement au focus (accessibilité). -->
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <Header />
    <AnnouncementBar />
    <main id="contenu">
      <slot />
    </main>
    <Footer />

    {
      /* Objectifs Plausible : un événement à chaque clic sur un numéro de
         téléphone ou un courriel (les conversions qui comptent pour un
         garage). Créez les objectifs du même nom dans Plausible. */
      analytics.enabled && (
        <script>
          document.addEventListener('click', (e) => {
            const link = (e.target as Element).closest?.('a[href^="tel:"], a[href^="mailto:"]');
            if (!link) return;
            const plausible = (window as any).plausible;
            if (typeof plausible !== 'function') return;
            const isTel = link.getAttribute('href')?.startsWith('tel:');
            plausible(isTel ? 'Appel téléphonique' : 'Courriel');
          });
        </script>
      )
    }
  </body>
</html>
