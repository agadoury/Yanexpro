---
/**
 * Bandeau d'appel à l'action réutilisable (bas de page intérieure).
 * Props facultatives pour adapter le message selon la page.
 */
import { business, booking } from '../data/business';
import Icon from './Icon.astro';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Prêt à prendre rendez-vous?',
  text = booking.enabled
    ? `Réservez en ligne en deux minutes, ou appelez-nous au ${business.phone.display}.`
    : `Appelez-nous au ${business.phone.display} — nous trouvons une plage horaire qui vous convient.`,
} = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="cta-band">
      <div>
        <h2>{title}</h2>
        <p>{text}</p>
      </div>
      <div class="cta-actions">
        {
          /* Réservation en ligne en action principale quand elle est
             activée ; sinon, l'appel téléphonique reste à l'avant-plan. */
          booking.enabled ? (
            <>
              <a class="btn btn--primary" href="/rendez-vous/">
                <Icon name="clock" size={18} /> Prendre rendez-vous en ligne
              </a>
              <a class="btn btn--ghost" href={`tel:${business.phone.e164}`}>
                <Icon name="phone" size={18} /> {business.phone.display}
              </a>
            </>
          ) : (
            <>
              <a class="btn btn--primary" href={`tel:${business.phone.e164}`}>
                <Icon name="phone" size={18} /> Appeler maintenant
              </a>
              <a class="btn btn--ghost" href="/contact/">
                Nous joindre <Icon name="arrow" size={18} />
              </a>
            </>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: linear-gradient(
      120deg,
      var(--color-bg-raised),
      var(--color-bg-deep)
    );
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }

  .cta-band h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin-bottom: 0.4rem;
  }

  .cta-band p {
    color: var(--color-text-muted);
    margin: 0;
    max-width: 34rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
