---
/**
 * En-tête de page intérieure : surtitre, titre H1 et phrase d'introduction.
 * Garantit une structure de titres cohérente (un seul H1 par page = bonne
 * pratique SEO).
 */
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<div class="page-hero">
  <div class="container">
    <span class="eyebrow">{eyebrow}</span>
    <h1>{title}</h1>
    {intro && <p>{intro}</p>}
  </div>
</div>

<style>
  .page-hero {
    padding-block: clamp(3rem, 7vw, 5rem);
    background:
      radial-gradient(
        60rem 30rem at 85% -20%,
        var(--color-accent-soft),
        transparent
      ),
      var(--color-bg-deep);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero h1 {
    font-size: var(--text-lg);
    max-width: 40rem;
  }

  .page-hero p {
    color: var(--color-text-muted);
    font-size: var(--text-md);
    max-width: 44rem;
    margin-bottom: 0;
  }
</style>
