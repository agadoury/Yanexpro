---
/**
 * Jeu d'icônes SVG du site (style trait, 24 × 24).
 *
 * Usage : <Icon name="wrench" size={28} />
 *
 * Pour ajouter une icône : ajoutez une entrée au dictionnaire `paths`
 * ci-dessous (contenu SVG interne seulement, le <svg> englobant est généré).
 * Les icônes sont injectées en ligne : aucune requête réseau, aucun poids.
 */
interface Props {
  name: string;
  size?: number;
}

const { name, size = 24 } = Astro.props;

const paths: Record<string, string> = {
  wrench:
    '<path d="M14.7 6.3a4.5 4.5 0 0 0-6 5.7L3 17.7V21h3.3l5.7-5.7a4.5 4.5 0 0 0 5.7-6L14.4 12l-2.4-2.4 2.7-3.3z"/>',
  brake:
    '<circle cx="12" cy="12" r="4"/><path d="M12 2a10 10 0 0 1 7.7 3.6M12 22a10 10 0 0 1-7.7-3.6M2.3 9a10 10 0 0 1 2-3.4M21.7 15a10 10 0 0 1-2 3.4"/>',
  diagnostic:
    '<path d="M3 12h4l2-7 4 14 2-7h6"/>',
  suspension:
    '<path d="M5 4h14M5 20h14M8 4c4 2.5-4 5 0 8s-4 5.5 0 8M16 4c4 2.5-4 5 0 8s-4 5.5 0 8"/>',
  tire:
    '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3.5"/><path d="M12 3v5.5M20.6 9.2l-5.3 1.7M17.3 19.3 14 14.9M6.7 19.3l3.3-4.4M3.4 9.2l5.3 1.7"/>',
  snowflake:
    '<path d="M12 2v20M4 6l16 12M20 6 4 18M9 4l3 3 3-3M9 20l3-3 3 3M3.5 9.5 7 11l-3.5 1.5M20.5 9.5 17 11l3.5 1.5"/>',
  exhaust:
    '<path d="M3 13h10a3 3 0 0 0 3-3V7h5"/><circle cx="19" cy="16" r="1"/><circle cx="16" cy="19" r="1"/><circle cx="20" cy="20" r="1"/><path d="M3 9v8"/>',
  bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8z"/>',
  clipboard:
    '<rect x="5" y="4" width="14" height="18" rx="2"/><path d="M9 2h6v4H9zM9 12l2 2 4-4"/>',
  truck:
    '<path d="M2 6h12v10H2zM14 9h4l3 3v4h-7z"/><circle cx="6.5" cy="17.5" r="1.8"/><circle cx="17" cy="17.5" r="1.8"/>',
  speaker:
    '<rect x="6" y="3" width="12" height="18" rx="2"/><circle cx="12" cy="14" r="3.5"/><circle cx="12" cy="7" r="1.2"/>',
  trailer:
    '<rect x="2" y="7" width="14" height="8" rx="1"/><path d="M16 11h6M2 15v2"/><circle cx="9" cy="17.5" r="1.8"/>',
  box: '<path d="M3 8 12 3l9 5v8l-9 5-9-5zM3 8l9 5 9-5M12 13v8"/>',
  car: '<path d="M4 16v3h2.5M20 16v3h-2.5M3 12l2-5.5A2 2 0 0 1 6.9 5h10.2a2 2 0 0 1 1.9 1.5L21 12v4H3z"/><circle cx="7" cy="13.5" r="1"/><circle cx="17" cy="13.5" r="1"/>',
  coffee:
    '<path d="M4 9h12v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4zM16 10h2.5a2.5 2.5 0 0 1 0 5H16M7 5c0-1 1-1 1-2M11 5c0-1 1-1 1-2"/>',
  shield:
    '<path d="M12 2 4.5 5v6c0 5 3.2 8.7 7.5 11 4.3-2.3 7.5-6 7.5-11V5z"/><path d="m9 11.5 2 2 4-4.5"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/>',
  phone:
    '<path d="M5 3h4l1.5 5L8 9.5a12 12 0 0 0 6.5 6.5L16 13.5l5 1.5v4a2 2 0 0 1-2 2A16 16 0 0 1 3 5a2 2 0 0 1 2-2z"/>',
  pin: '<path d="M12 21s-7-6.1-7-11a7 7 0 0 1 14 0c0 4.9-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  mail:
    '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
};

const path = paths[name] ?? paths['wrench'];
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={path}
/>
