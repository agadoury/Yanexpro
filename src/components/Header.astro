---
/**
 * En-tête du site : logo, navigation principale et bouton d'appel.
 *
 * - La navigation est définie dans le tableau `navItems` ci-dessous.
 * - Le lien de la page courante est mis en évidence automatiquement
 *   (attribut `aria-current`, utile aussi pour l'accessibilité).
 * - Sur mobile, le menu se replie derrière un bouton hamburger
 *   (3 lignes de JavaScript, voir <script> en bas de fichier).
 */
import { business, booking } from '../data/business';
import Icon from './Icon.astro';
import Logo from './Logo.astro';

const navItems = [
  { label: 'Accueil', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: 'Notre garage', href: '/garage/' },
  { label: 'Remorques', href: '/remorques/' },
  // L'entrée « Rendez-vous » apparaît quand la réservation en ligne est
  // activée (booking.enabled dans src/data/business.ts).
  ...(booking.enabled
    ? [{ label: 'Rendez-vous', href: '/rendez-vous/' }]
    : []),
  { label: 'FAQ', href: '/faq/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname.replace(/\/?$/, '/');
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${business.shortName} — Accueil`}>
      <Logo size={44} />
      <span class="brand-text">
        {business.shortName}<span class="brand-sub">Mécanique Auto</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Ouvrir le menu"
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Navigation principale">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a class="btn btn--primary header-cta" href={`tel:${business.phone.e164}`}>
        <Icon name="phone" size={18} />
        {business.phone.display}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 13, 16, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 4.25rem;
  }

  /* --- Logo --- */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }
  .brand:hover {
    text-decoration: none;
  }
  /* Lettrage assorti au logo officiel : capitales grasses + sous-titre. */
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    font-weight: 850;
    font-size: 1.15rem;
    color: var(--color-heading);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .brand-sub {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  /* --- Navigation --- */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .site-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-nav ul a {
    display: block;
    padding: 0.5rem 0.85rem;
    border-radius: 0.5rem;
    color: var(--color-text);
    font-weight: 550;
    font-size: 0.95rem;
  }
  .site-nav ul a:hover {
    text-decoration: none;
    background: var(--color-bg-raised);
  }
  .site-nav ul a[aria-current='page'] {
    color: var(--color-accent-hover);
  }
  .header-cta {
    padding: 0.55rem 1.1rem;
    font-size: 0.92rem;
    white-space: nowrap;
  }

  /* --- Bouton hamburger (mobile) --- */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
  }
  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- Adaptation mobile --- */
  @media (max-width: 860px) {
    .nav-toggle {
      display: flex;
    }
    .site-nav {
      display: none;
      position: absolute;
      inset: 100% 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
      background: var(--color-bg-deep);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem clamp(1.25rem, 4vw, 2rem) 1.5rem;
    }
    .site-nav.is-open {
      display: flex;
    }
    .site-nav ul {
      flex-direction: column;
      gap: 0;
    }
    .site-nav ul a {
      padding: 0.8rem 0.5rem;
      font-size: 1.05rem;
    }
    .header-cta {
      justify-content: center;
    }
  }
</style>

<script>
  // Ouverture / fermeture du menu mobile.
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(open)));
    toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
  });
</script>
