---
/**
 * PAGE FAQ — https://yanexpro.com/faq/
 *
 * Les questions/réponses proviennent de `src/data/faq.ts`. La page injecte
 * aussi des données structurées « FAQPage » (schema.org) : Google peut
 * afficher les questions directement dans ses résultats, et les assistants
 * IA s'en servent pour répondre avec les bonnes informations.
 *
 * Affichage en accordéon natif (<details>/<summary>) : aucun JavaScript,
 * accessible au clavier, et tout le texte reste indexable.
 */
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqs } from '../data/faq';

/** Données structurées FAQPage — réponses en texte brut (sans balises). */
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer.replace(/<[^>]+>/g, ''),
    },
  })),
};
---

<Layout
  title="Questions fréquentes | Yanexpro Mécanique Auto, Varennes"
  description="Garantie de constructeur hors concessionnaire, pneus d'hiver au Québec, voitures de courtoisie, inspection pré-achat, location de remorques : les réponses de Yanexpro Mécanique Auto."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqJsonLd)}
    slot="head"
  />

  <PageHero
    eyebrow="FAQ"
    title="Questions fréquentes"
    intro="Les réponses claires aux questions qu’on nous pose le plus souvent — garantie, pneus d’hiver, rendez-vous et plus. Vous ne trouvez pas la vôtre? Appelez-nous, ça nous fera plaisir."
  />

  <section class="section" aria-label="Questions et réponses">
    <div class="container faq-list">
      {
        faqs.map((f, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>
              <h2>{f.question}</h2>
              <span class="faq-marker" aria-hidden="true" />
            </summary>
            <div class="faq-answer" set:html={f.answer} />
          </details>
        ))
      }
    </div>
  </section>

  <CtaBand
    title="Une autre question?"
    text="Appelez-nous — un vrai humain du garage vous répond, pas un menu téléphonique."
  />
</Layout>

<style>
  .faq-list {
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item[open] {
    border-color: var(--color-accent);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    list-style: none; /* retire le triangle natif */
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary h2 {
    font-size: 1.05rem;
    margin: 0;
    line-height: 1.4;
  }

  /* Indicateur +/− dessiné en CSS. */
  .faq-marker {
    position: relative;
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
  }

  .faq-marker::before,
  .faq-marker::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto;
    height: 2px;
    background: var(--color-accent-hover);
    border-radius: 2px;
    transition: transform 0.18s ease;
  }

  .faq-marker::after {
    transform: rotate(90deg);
  }

  .faq-item[open] .faq-marker::after {
    transform: rotate(0deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.4rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .faq-answer :global(a) {
    color: var(--color-accent-hover);
  }

  .faq-answer :global(strong) {
    color: var(--color-text);
  }
</style>
